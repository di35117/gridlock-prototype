docker-compose.override.yml

# ── IDE ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Database / cache ─────────────────────────────────────
*.db
*.sqlite
*.sqlite3
redis-data/

