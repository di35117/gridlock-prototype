data/*.csv
data/*.graphml
data/*.pkl
data/*.joblib
data/*.model
data/*.parquet
data/*.feather

# ── ML model artifacts ───────────────────────────────────
backend/models/saved/
*.lgbm
*.pkl
*.joblib

# ── Logs ─────────────────────────────────────────────────
*.log
logs/

